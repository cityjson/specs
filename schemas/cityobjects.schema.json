{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://www.cityjson.org/schemas/2.0.1/cityobjects.schema.json",
  "title": "CityJSON City Objects schema v2.0.1",
  "ExtensionObject": {
    "title": "ExtensionObject",
    "type": "object",
    "properties": {
      "type": {
        "type": "string",
        "pattern": "(\\+)([A-Z])\\w+"
      }
    },
    "required": [
      "type"
    ]
  },
  "_AbstractCityObject": {
    "title": "_AbstractCityObject",
    "properties": {
      "attributes": {
        "type": "object"
      },
      "parents": {
        "type": "array",
        "description": "the IDs of the parents",
        "items": {
          "type": "string"
        }
      },
      "children": {
        "type": "array",
        "description": "the IDs of children",
        "items": {
          "type": "string"
        }
      },
      "geographicalExtent": {
        "type": "array",
        "items": {
          "type": "number"
        },
        "minItems": 6,
        "maxItems": 6
      }
    }
  },
  "OtherConstruction": {
    "title": "OtherConstruction",
    "allOf": [
      {
        "$ref": "#/_AbstractCityObject"
      },
      {
        "title": "OtherConstruction",
        "properties": {
          "type": {
            "const": "OtherConstruction"
          },
          "geometry": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "$ref": "geomprimitives.schema.json#/$defs/MultiPoint"
                },
                {
                  "$ref": "geomprimitives.schema.json#/$defs/MultiLineString"
                },
                {
                  "$ref": "geomprimitives.schema.json#/$defs/MultiSurface"
                },
                {
                  "$ref": "geomprimitives.schema.json#/$defs/CompositeSurface"
                },
                {
                  "$ref": "geomprimitives.schema.json#/$defs/Solid"
                },
                {
                  "$ref": "geomprimitives.schema.json#/$defs/CompositeSolid"
                },
                {
                  "$ref": "geomprimitives.schema.json#/$defs/MultiSolid"
                },
                {
                  "$ref": "geomtemplates.schema.json#/GeometryInstance"
                }
              ]
            }
          }
        },
        "required": [
          "type"
        ]
      }
    ]
  },
  "_AbstractBuilding": {
    "allOf": [
      {
        "$ref": "#/_AbstractCityObject"
      },
      {
        "title": "_AbstractBuilding",
        "properties": {
          "address": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "location": {
                  "$ref": "geomprimitives.schema.json#/$defs/MultiPoint"
