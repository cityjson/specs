                },
                {
                  "$ref": "geomprimitives.schema.json#/Solid"
                },
                {
                  "$ref": "geomprimitives.schema.json#/CompositeSolid"
                },
                {
                  "$ref": "geomprimitives.schema.json#/MultiSolid"
                },
                {
                  "$ref": "geomtemplates.schema.json#/GeometryInstance"
                }
              ]
            }
          }
        },
        "required": [
          "type"
        ]
      }
    ]
  },
  "_AbstractBuilding": {
